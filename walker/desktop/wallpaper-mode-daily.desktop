[Desktop Entry]
Type=Application
Name=Wallpaper: Mode Daily
Comment=Rotate a fresh Wallhaven pick each day
Exec=sh -c "PATH=\$HOME/Code/go/bin:\$HOME/go/bin:\$HOME/.local/bin:\$PATH exec wallhaven-rotator mode daily"
