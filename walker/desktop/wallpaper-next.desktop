[Desktop Entry]
Type=Application
Name=Wallpaper: Next
Comment=Fetch and apply a fresh wallpaper from Wallhaven
Exec=sh -c "PATH=\$HOME/Code/go/bin:\$HOME/go/bin:\$HOME/.local/bin:\$PATH exec wallhaven-rotator next"
