[Desktop Entry]
Type=Application
Name=Wallpaper: Unfavorite
Comment=Remove the current wallpaper from favorites
Exec=sh -c "PATH=\$HOME/Code/go/bin:\$HOME/go/bin:\$HOME/.local/bin:\$PATH exec wallhaven-rotator unfavorite"
Icon=non-starred
Terminal=false
Categories=Utility;
Keywords=wallpaper;unfavorite;remove;
